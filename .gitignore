# ============================================================
# Virtual Environment — never push this to GitHub (it's huge)
# ============================================================
.venv_gpu/
.venv/
venv/
env/

# ============================================================
# Dataset files — too large for GitHub, user downloads from Kaggle
# ============================================================
data/
*.csv
*.zip
*.gz
*.tar

# ============================================================
# Python cache — auto-generated, not needed in repo
# ============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ============================================================
# Jupyter Notebook checkpoints — auto-generated temp files
# ============================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# ============================================================
# Saved model files — can be large, regenerated by running notebook
# ============================================================
*.pkl
*.joblib
*.model
*.bin
*.h5

# Track specific pre-trained models so the local Gradio app runs immediately upon cloning
!outputs/lung_cancer_app_data.pkl
!app/lung_cancer_app_data.pkl

# ============================================================
# Kaggle API credentials — NEVER expose your API key
# ============================================================
kaggle.json
.kaggle/

# ============================================================
# Hugging Face credentials
# ============================================================
.huggingface/

# ============================================================
# Environment variables / secrets
# ============================================================
.env
.env.local
secrets.yaml

# ============================================================
# OS-generated junk files & Temporary application outputs
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
temp_*.png

# ============================================================
# IDE/Editor folders
# ============================================================
.vscode/
.idea/
*.code-workspace
